{
	"name": "browse",
	"version": "0.4.3",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"lint": "biome lint .",
		"build": "bun build --compile ./src/cli.ts --outfile dist/browse --external electron --external chromium-bidi",
		"test": "bun test",
		"test:integration": "bun run test/integration.ts",
		"prepare": "git rev-parse --git-dir >/dev/null 2>&1 && lefthook install || true"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "latest",
		"lefthook": "^2.1.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@axe-core/playwright": "^4.11.1",
		"playwright": "^1.58.2",
		"user-agents": "^1.1.669"
	},
	"patchedDependencies": {
		"playwright-core@1.58.2": "patches/playwright-core@1.58.2.patch",
		"playwright@1.58.2": "patches/playwright@1.58.2.patch"
	}
}
