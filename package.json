{
	"name": "browse",
	"version": "0.12.3",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"lint": "biome lint .",
		"build": "bun build --compile ./src/cli.ts --outfile dist/browse --external electron --external chromium-bidi",
		"test": "bun test",
		"test:integration": "bun run test/integration.ts",
		"prepare": "git rev-parse --git-dir >/dev/null 2>&1 && lefthook install || true"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "latest",
		"fast-check": "^4.6.0",
		"lefthook": "^2.1.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@axe-core/playwright": "^4.11.1",
		"playwright": "npm:patchright@1.58.2",
		"playwright-core": "npm:patchright-core@1.58.2"
	},
	"patchedDependencies": {
		"patchright-core@1.58.2": "patches/patchright-core@1.58.2.patch",
		"patchright@1.58.2": "patches/patchright@1.58.2.patch"
	}
}
