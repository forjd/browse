{
	"name": "bun-browser",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"check": "biome check .",
		"check:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"lint": "biome lint .",
		"build": "bun build --compile ./src/cli.ts --outfile dist/browse --external playwright --external playwright-core",
		"test": "bun test",
		"test:integration": "bun run test/integration.ts",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "latest",
		"lefthook": "^2.1.4"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"playwright": "^1.58.2"
	}
}
